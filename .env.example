NEXT_PUBLIC_SITE_URL=https://kcg-confirm-preview.vercel.app

# Supabase is optional for local operation; without it, the checked-in seed data is used.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin access. Use real secrets only in Vercel/project env, never in git.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Market data provider:
# auto | metals-dev | gold-api | mock
MARKET_DATA_PROVIDER=auto
METALS_DEV_API_KEY=
MARKET_DATA_REVALIDATE_SECONDS=60

# Keep non-public deployments out of search indexes until public launch approval.
KCG_FORCE_NOINDEX=1
