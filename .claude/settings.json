      "Bash(npm *)",
      "Bash(node *)",
      "Bash(npx playwright *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git fetch*)",
      "Bash(vercel inspect*)",
      "Bash(vercel list*)",
      "PowerShell(npm *)",
      "PowerShell(node *)",
      "PowerShell(npx playwright *)",
      "PowerShell(git status*)",
      "PowerShell(git diff*)",
      "PowerShell(git log*)",
      "PowerShell(git show*)",
      "PowerShell(git fetch*)",
      "PowerShell(vercel inspect*)",
      "PowerShell(vercel list*)"
    ],
    "ask": [
      "Bash(npx *)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git restore*)",
      "Bash(git stash*)",
      "Bash(git pull*)",
      "Bash(git push*)",
      "Bash(supabase *)",
      "Bash(vercel link*)",
      "Bash(vercel pull*)",
      "Bash(vercel env*)",
      "Bash(vercel logs*)",
      "Bash(vercel deploy*)",
      "Bash(vercel alias*)",
      "Bash(npm publish*)",
      "PowerShell(npx *)",
      "PowerShell(git add*)",
      "PowerShell(git commit*)",
      "PowerShell(git checkout*)",
      "PowerShell(git switch*)",
      "PowerShell(git restore*)",
      "PowerShell(git stash*)",
      "PowerShell(git pull*)",
      "PowerShell(git push*)",
      "PowerShell(supabase *)",
      "PowerShell(vercel link*)",
      "PowerShell(vercel pull*)",
      "PowerShell(vercel env*)",
      "PowerShell(vercel logs*)",
      "PowerShell(vercel deploy*)",
      "PowerShell(vercel alias*)",
      "PowerShell(npm publish*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.vercel/**)",
      "Read(./supabase/.temp/**)",
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf .*)",
      "PowerShell(git reset --hard*)",
      "PowerShell(Remove-Item -Recurse -Force C:\\*)",
      "PowerShell(Remove-Item -Recurse -Force .*)"
    ]
  }
